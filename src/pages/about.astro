---
import Base from '../layouts/Base.astro';
---

<Base
  title="About — Sarah Chen"
  description="About Sarah Chen — an independent brand designer working between London and the quieter end of New York."
>
  <section class="px-6 md:px-12 pt-16 md:pt-24 pb-16">
    <div class="mx-auto max-w-[1400px] grid md:grid-cols-12 gap-10">
      <div class="md:col-span-7">
        <p class="eyebrow mb-8">About</p>
        <h1 class="display text-5xl md:text-8xl leading-[0.95]">
          Making brands that <span class="display-italic">whisper</span>, not shout.
        </h1>
      </div>
      <div class="md:col-span-4 md:col-start-9 self-end">
        <p class="text-lg leading-relaxed text-[var(--color-muted)]">
          Sarah Chen is a British-Taiwanese brand designer based in London, working with
          clients worldwide across fashion, publishing, hospitality, and the arts.
        </p>
      </div>
    </div>
  </section>

  <section class="px-6 md:px-12 pb-24">
    <div class="mx-auto max-w-[1400px]">
      <div class="hairline mb-16"></div>
      <div class="grid md:grid-cols-12 gap-10">
        <div class="md:col-span-3">
          <p class="eyebrow">Practice</p>
        </div>
        <div class="md:col-span-8 md:col-start-5 space-y-6 text-lg md:text-xl leading-relaxed">
          <p>
            I run a deliberately small, independent studio. Most projects are led
            entirely by me, from first conversation to final handover. That model
            keeps the work slow, specific, and unmistakably made by a person.
          </p>
          <p>
            The through-line across a decade of projects has been typography —
            a belief that type is the most honest element of an identity, the one
            that carries voice even when everything else falls away.
          </p>
          <p>
            Before going independent in 2018, I was a senior designer at
            Pentagram London and, earlier, in the art department at MatchesFashion.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 md:px-12 py-24 md:py-32 bg-[var(--color-bone)]">
    <div class="mx-auto max-w-[1400px] grid md:grid-cols-12 gap-10">
      <div class="md:col-span-4">
        <p class="eyebrow mb-4">Selected clients</p>
        <h2 class="display text-4xl md:text-5xl leading-none">
          A partial list.
        </h2>
      </div>
      <div class="md:col-span-7 md:col-start-6 text-lg md:text-xl leading-loose text-[var(--color-muted)]">
        <p>
          Atelier Blanc · Meridian Roasters · Fold Architecture · Lumen Skincare
          · North Gallery · Heirloom Press · Kindred &amp; Co. · Rook Journal ·
          Bessemer Hotel · Studio Ōra · Field Notes Edition · Monocle (editorial
          contributor).
        </p>
      </div>
    </div>
  </section>

  <section class="px-6 md:px-12 pt-24 pb-24">
    <div class="mx-auto max-w-[1400px] grid md:grid-cols-12 gap-10">
      <div class="md:col-span-3">
        <p class="eyebrow">Recognition</p>
      </div>
      <ul class="md:col-span-8 md:col-start-5 space-y-4 text-lg">
        <li class="flex justify-between gap-6 items-baseline">
          <span>D&amp;AD Wood Pencil — Branding</span>
          <span class="display-italic text-[var(--color-muted)]">2024</span>
        </li>
        <li class="hairline"></li>
        <li class="flex justify-between gap-6 items-baseline">
          <span>Brand New — Noted</span>
          <span class="display-italic text-[var(--color-muted)]">2023</span>
        </li>
        <li class="hairline"></li>
        <li class="flex justify-between gap-6 items-baseline">
          <span>TDC New York · Certificate of Typographic Excellence</span>
          <span class="display-italic text-[var(--color-muted)]">2022</span>
        </li>
        <li class="hairline"></li>
        <li class="flex justify-between gap-6 items-baseline">
          <span>It&apos;s Nice That — Graphic Design of the Year (shortlist)</span>
          <span class="display-italic text-[var(--color-muted)]">2021</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="px-6 md:px-12 pb-32">
    <div class="mx-auto max-w-[1400px]">
      <div class="hairline mb-10"></div>
      <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-6">
        <p class="display text-3xl md:text-5xl max-w-[22ch]">
          Currently booking projects for next quarter.
        </p>
        <a href="/contact" class="link-underline display-italic text-2xl md:text-3xl">
          Start a conversation →
        </a>
      </div>
    </div>
  </section>
</Base>
