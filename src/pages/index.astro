---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getProjects } from '../lib/supabase';

const projects = await getProjects();
const featured = projects.slice(0, 6);
---

<Base
  title="Sarah Chen — Freelance Brand Designer"
  description="Sarah Chen is an independent brand designer building typographic, considered identity systems for studios, publishers, and fashion houses."
>
  <!-- Hero -->
  <section class="px-6 md:px-12 pt-16 md:pt-28 pb-24 md:pb-40">
    <div class="mx-auto max-w-[1400px]">
      <p class="eyebrow mb-10">Independent brand designer · London</p>
      <h1 class="display text-[10vw] md:text-[7.5rem] lg:text-[9rem] leading-[0.9] max-w-[18ch]">
        Quiet identity<br />
        systems for <span class="display-italic">careful</span> brands.
      </h1>
      <div class="mt-14 grid md:grid-cols-12 gap-6">
        <div class="md:col-span-5 md:col-start-7">
          <p class="text-base md:text-lg leading-relaxed text-[var(--color-muted)]">
            I&apos;m Sarah — a freelance brand designer working with founders, publishers,
            and emerging fashion houses. My practice is rooted in typography, restraint,
            and a belief that the best identities reveal themselves slowly.
          </p>
          <div class="mt-8 flex items-baseline gap-6">
            <a href="/work" class="link-underline text-sm tracking-wide">Selected work →</a>
            <a href="/contact" class="link-underline text-sm tracking-wide text-[var(--color-muted)]">
              Start a project
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  <section class="px-6 md:px-12 pb-32">
    <div class="mx-auto max-w-[1400px]">
      <div class="flex items-baseline justify-between mb-14">
        <div>
          <p class="eyebrow mb-3">Selected work</p>
          <h2 class="display text-4xl md:text-6xl">Recent projects</h2>
        </div>
        <a href="/work" class="hidden md:inline-block link-underline text-sm tracking-wide">
          View index →
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-20">
        {featured.map((project, i) => (
          <ProjectCard project={project} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities strip -->
  <section class="px-6 md:px-12 py-24 md:py-32 bg-[var(--color-bone)]">
    <div class="mx-auto max-w-[1400px] grid md:grid-cols-12 gap-10">
      <div class="md:col-span-4">
        <p class="eyebrow mb-4">Capabilities</p>
        <h2 class="display text-4xl md:text-5xl">A generalist practice, built around type.</h2>
      </div>
      <div class="md:col-span-7 md:col-start-6 text-lg leading-relaxed space-y-6 text-[var(--color-muted)]">
        <p>
          Visual identity · Logotypes &amp; wordmarks · Packaging systems · Editorial
          &amp; book design · Art direction · Type selection &amp; custom lettering ·
          Website art direction.
        </p>
        <p>
          Projects run from six-week identity sprints to year-long engagements.
          I work solo, and partner with trusted collaborators for strategy,
          development, and motion when a project calls for it.
        </p>
      </div>
    </div>
  </section>
</Base>
