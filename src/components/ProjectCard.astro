---
import type { Project } from '../lib/supabase';

interface Props {
  project: Project;
  index: number;
}
const { project, index } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<a href={`/work/${project.slug}`} class="group block">
  <div
    class="relative aspect-[4/5] overflow-hidden bg-[var(--color-bone)]"
    style={`background-color: ${project.accent_color ?? '#e8e1d5'};`}
  >
    {project.cover_image_url && (
      <img
        src={project.cover_image_url}
        alt={project.title}
        class="h-full w-full object-cover transition duration-[900ms] ease-out group-hover:scale-[1.03]"
        loading="lazy"
      />
    )}
    <div class="absolute left-4 top-4 text-xs tracking-[0.22em] text-white/80 mix-blend-difference">
      {num}
    </div>
  </div>
  <div class="pt-5 flex items-baseline justify-between gap-6">
    <div>
      <h3 class="display text-2xl md:text-3xl">{project.title}</h3>
      <p class="text-sm text-[var(--color-muted)] mt-1">
        {project.category}{project.client ? ` · ${project.client}` : ''}
      </p>
    </div>
    <span class="display-italic text-sm text-[var(--color-muted)] whitespace-nowrap">
      {project.year}
    </span>
  </div>
</a>
