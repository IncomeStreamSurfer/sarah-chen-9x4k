---
const pathname = Astro.url.pathname;
const items = [
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="px-6 md:px-12 pt-8 pb-6">
  <div class="mx-auto max-w-[1400px] flex items-baseline justify-between">
    <a href="/" class="display text-xl md:text-2xl tracking-tight">
      Sarah Chen<span class="display-italic text-[var(--color-muted)]">, studio</span>
    </a>
    <nav class="flex items-baseline gap-8 text-sm">
      {items.map((item) => {
        const active = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
        return (
          <a
            href={item.href}
            class={`link-underline tracking-wide ${active ? 'text-[var(--color-ink)]' : 'text-[var(--color-muted)]'}`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>
