---
const year = new Date().getFullYear();
---

<footer class="px-6 md:px-12 pt-32 pb-10">
  <div class="mx-auto max-w-[1400px]">
    <div class="hairline mb-10"></div>
    <div class="grid md:grid-cols-3 gap-10 md:gap-6">
      <div>
        <p class="eyebrow mb-3">Studio</p>
        <p class="display text-3xl md:text-4xl leading-none">Sarah Chen</p>
        <p class="display-italic text-[var(--color-muted)] mt-1">Brand design &amp; identity</p>
      </div>
      <div>
        <p class="eyebrow mb-3">Elsewhere</p>
        <ul class="space-y-2 text-sm">
          <li><a href="#" class="link-underline">Instagram</a></li>
          <li><a href="#" class="link-underline">Are.na</a></li>
          <li><a href="#" class="link-underline">LinkedIn</a></li>
        </ul>
      </div>
      <div>
        <p class="eyebrow mb-3">New enquiries</p>
        <a href="/contact" class="display-italic text-2xl link-underline">hello@sarahchen.studio</a>
        <p class="text-sm text-[var(--color-muted)] mt-3">
          Taking on a small number of projects each quarter.
        </p>
      </div>
    </div>
    <div class="mt-16 flex flex-col md:flex-row md:items-center md:justify-between gap-3 text-xs text-[var(--color-muted)]">
      <span>© {year} Sarah Chen Studio. All rights reserved.</span>
      <span class="display-italic">Designed in London · Working worldwide</span>
    </div>
  </div>
</footer>
